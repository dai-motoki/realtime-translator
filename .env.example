# OpenAI API key with access to the Realtime / gpt-realtime-translate model.
# Used only on the server to mint short-lived client secrets — never exposed to the browser.
OPENAI_API_KEY=sk-...

# (Optional) Model used to refine/optimize each finalized line after the
# real-time pass, using the full conversation history. Defaults to gpt-5.5.
# REFINE_MODEL=gpt-5.5

# (Optional) Model used to write the meeting minutes (議事録) for a saved
# conversation. Defaults to REFINE_MODEL, then gpt-5.5.
# MINUTES_MODEL=gpt-5.5

# (Optional) Speaker diarization (話者識別) via Picovoice Falcon — runs fully in
# the browser (WASM), no audio leaves the device. Leave these unset to disable
# the feature entirely (the app then behaves exactly as before).
#  1. Get a free AccessKey at https://console.picovoice.ai/
#  2. Download the Falcon model `falcon_params.pv` from
#     https://github.com/Picovoice/falcon/tree/main/lib/common
#     and place it at `public/models/falcon_params.pv`.
# This is a NEXT_PUBLIC_ var: it's shipped to the browser (Picovoice keys are
# meant to be client-side).
# NEXT_PUBLIC_PICOVOICE_ACCESS_KEY=
# (Optional) Override the model path if you put it somewhere else under public/.
# NEXT_PUBLIC_FALCON_MODEL_PATH=/models/falcon_params.pv
